# Secrets / local config — ONLY the repo-root config.php (real credentials).
# Leading slash anchors it to root so it does NOT also ignore src/lib/config.php
# (the config LOADER, which is source code with no secrets).
/config.php

# Per-deployment private-code path pointer (written by deploy/sync.py on the
# public target; see public/paths.php). Machine/host-specific, never committed.
public/private_path.local.php

# Dependencies
/vendor/
/node_modules/

# OS / editor cruft
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/*
!.vscode/extensions.json

# Logs & temp
*.log
/tmp/

deploy.local.env

# Uploaded sound files (keep the folder, ignore large audio) — served from under
# public/ since the webroot is public/ (Spec §9); starter/seeded packs are tracked
# explicitly below despite the pattern.
public/assets/sounds/**/*.mp3
public/assets/sounds/**/*.wav
public/assets/sounds/**/*.ogg
!public/assets/sounds/default/*.wav
!public/assets/sounds/klasyczny/*.wav
