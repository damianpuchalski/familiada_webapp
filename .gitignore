# Secrets / local config
config.php

# Dependencies
/vendor/
/node_modules/

# OS / editor cruft
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/*
!.vscode/extensions.json

# Logs & temp
*.log
/tmp/

# Uploaded sound files (keep the folder, ignore large audio) — served from under
# public/ since the webroot is public/ (Spec §9); starter/seeded packs are tracked
# explicitly below despite the pattern.
public/assets/sounds/**/*.mp3
public/assets/sounds/**/*.wav
public/assets/sounds/**/*.ogg
!public/assets/sounds/default/*.wav
!public/assets/sounds/klasyczny/*.wav
